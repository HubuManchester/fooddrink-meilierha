<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Pages.FoodDetailPage"
             Title="Food Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame CornerRadius="20" 
                   BackgroundColor="#F5F5F5"
                   HeightRequest="220"
                   HasShadow="False"
                   Padding="0">
                <Grid>
                    <Image x:Name="FoodPhotoImage"
                           Aspect="AspectFill"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           IsVisible="False"/>
                    <Label x:Name="FoodEmojiLabel"
                           Text="🍲"
                           FontSize="80"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           IsVisible="True"/>
                </Grid>
            </Frame>

            <Label x:Name="NameLabel" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#333333"/>

            <Frame CornerRadius="15"
                   BackgroundColor="#4CAF50"
                   Padding="12,5"
                   HorizontalOptions="Center"
                   HasShadow="False">
                <Label x:Name="TypeLabel"
                       FontSize="16" 
                       TextColor="White"/>
            </Frame>

            <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,10"/>

            <Label Text="📋 Cooking Steps" 
                   FontSize="20" 
                   FontAttributes="Bold"
                   TextColor="#333333"/>

            <Label x:Name="StepsLabel" 
                   FontSize="15" 
                   TextColor="#555555"/>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,20,0,0">
                <Button Text="🔊 Read Aloud"
                        BackgroundColor="#9C27B0"
                        TextColor="White"
                        CornerRadius="15"
                        HeightRequest="50"
                        FontSize="16"
                        FontAttributes="Bold"
                        Clicked="OnSpeakClicked"/>

                <Button Text="⏹️ Stop"
                        Grid.Column="1"
                        BackgroundColor="#FF5722"
                        TextColor="White"
                        CornerRadius="15"
                        HeightRequest="50"
                        FontSize="16"
                        FontAttributes="Bold"
                        Clicked="OnStopSpeakingClicked"/>
            </Grid>

            <Label Text="Tap 'Read Aloud' to hear the cooking steps. Tap 'Stop' to cancel." 
                   FontSize="11" 
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,5"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>