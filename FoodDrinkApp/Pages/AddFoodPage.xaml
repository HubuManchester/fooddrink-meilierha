<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Pages.AddFoodPage"
             Title="Add New Food">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="🍽️ Add New Recipe" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#333333"/>

            <!-- 拍照区域 -->
            <Frame BorderColor="#E0E0E0" 
                   CornerRadius="12"
                   Padding="0"
                   BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                   HasShadow="False">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Button x:Name="TakePhotoButton"
                            Text="📸 Take Photo"
                            BackgroundColor="#D9472B"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            Clicked="OnTakePhotoClicked"
                            Margin="10,10,10,0"
                            SemanticProperties.Hint="Take a photo of your food"/>

                    <Frame Grid.Row="1"
                           BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"
                           HeightRequest="120"
                           Margin="10,0,10,10"
                           CornerRadius="8"
                           Padding="0"
                           HasShadow="False">
                        <Image x:Name="FoodPhotoPreview"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               HeightRequest="100"/>
                    </Frame>
                </Grid>
            </Frame>

            <Label Text="Food Name *" 
                   FontSize="14" 
                   FontAttributes="Bold"
                   TextColor="#666666"/>
            <Entry x:Name="NameEntry"
                   Placeholder="e.g., Spaghetti Bolognese"
                   PlaceholderColor="LightGray"
                   FontSize="16"
                   BackgroundColor="#F5F5F5"
                   Margin="0,5,0,0"/>

            <Label Text="Food Type *" 
                   FontSize="14" 
                   FontAttributes="Bold"
                   TextColor="#666666"/>
            <Picker x:Name="CategoryPicker"
                    Title="Select category"
                    BackgroundColor="#F5F5F5"
                    Margin="0,5,0,0">
                <Picker.Items>
                    <x:String>Breakfast</x:String>
                    <x:String>Lunch</x:String>
                    <x:String>Dinner</x:String>
                    <x:String>Snack</x:String>
                    <x:String>Drink</x:String>
                    <x:String>Dessert</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Cooking Steps" 
                   FontSize="14" 
                   FontAttributes="Bold"
                   TextColor="#666666"/>
            <Editor x:Name="StepsEditor"
                    Placeholder="1. First step...&#x0a;2. Second step...&#x0a;3. Third step..."
                    PlaceholderColor="LightGray"
                    HeightRequest="120"
                    FontSize="14"
                    BackgroundColor="#F5F5F5"
                    Margin="0,5,0,0"/>

            <Label x:Name="ValidationLabel" 
                   Text="" 
                   TextColor="Red"
                   FontSize="13"
                   IsVisible="False"/>

            <Button Text="Submit Food"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="15"
                    HeightRequest="50"
                    FontSize="16"
                    FontAttributes="Bold"
                    Clicked="OnSubmitClicked"
                    Margin="0,20,0,0"/>

            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="#4CAF50"
                               HeightRequest="40"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>