<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Pages.EditFoodPage"
             Title="Edit Food">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="✏️ Edit Recipe" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center"
                   TextColor="#333333"/>

            <!-- 拍照区域 - 完全参照 AddFoodPage -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Food Photo" 
                                   FontSize="17" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                            <Label Text="Capture the colour and condition of the meal." 
                                   FontSize="13" 
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Photo"
                                BackgroundColor="#D9472B"
                                TextColor="#FFFFFF"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open the camera to capture a food image" />
                    </Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#312316}"
                            HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <!-- 注意：这里的 x:Name 是 FoodPhotoPreview，和 AddFoodPage 一致 -->
                        <Image x:Name="FoodPhotoPreview"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Captured food photo preview" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Label Text="Food Name *" 
                   FontSize="14" 
                   FontAttributes="Bold"
                   TextColor="#666666"/>
            <Entry x:Name="NameEntry"
                   Placeholder="Food name"
                   FontSize="16"
                   BackgroundColor="#F5F5F5"
                   Margin="0,5,0,0"/>

            <Label Text="Food Type *" 
                   FontSize="14" 
                   FontAttributes="Bold"
                   TextColor="#666666"/>
            <Picker x:Name="CategoryPicker"
                    Title="Select category"
                    BackgroundColor="#F5F5F5"
                    Margin="0,5,0,0">
                <Picker.Items>
                    <x:String>Breakfast</x:String>
                    <x:String>Lunch</x:String>
                    <x:String>Dinner</x:String>
                    <x:String>Snack</x:String>
                    <x:String>Drink</x:String>
                    <x:String>Dessert</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Cooking Steps" 
                   FontSize="14" 
                   FontAttributes="Bold"
                   TextColor="#666666"/>
            <Editor x:Name="StepsEditor"
                    Placeholder="Cooking steps..."
                    HeightRequest="120"
                    FontSize="14"
                    BackgroundColor="#F5F5F5"
                    Margin="0,5,0,0"/>

            <Label x:Name="ValidationLabel" 
                   Text="" 
                   TextColor="Red"
                   FontSize="13"
                   IsVisible="False"/>

            <Button Text="Save Changes"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="15"
                    HeightRequest="50"
                    FontSize="16"
                    FontAttributes="Bold"
                    Clicked="OnSaveClicked"
                    Margin="0,20,0,0"/>

            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False"
                               IsRunning="False"
                               Color="#4CAF50"
                               HeightRequest="40"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>